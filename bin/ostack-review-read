#!/usr/bin/env bash
# ostack-review-read — read review log and config for dashboard
# Usage: ostack-review-read
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/ostack-slug" 2>/dev/null)"
OSTACK_HOME="${OSTACK_HOME:-$HOME/.ostack}"
cat "$OSTACK_HOME/projects/$SLUG/$BRANCH-reviews.jsonl" 2>/dev/null || echo "NO_REVIEWS"
echo "---CONFIG---"
"$SCRIPT_DIR/ostack-config" get skip_eng_review 2>/dev/null || echo "false"
echo "---HEAD---"
git rev-parse --short HEAD 2>/dev/null || echo "unknown"
